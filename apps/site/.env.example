# Local development for @partha/site (port 4001)
#
#   cp .env.example .env.local

NODE_ENV=development

# Marketing site origin (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:4001

# Core app — login / signup CTAs
NEXT_PUBLIC_APP_URL=http://localhost:4000

# Docs app — /docs redirect target
NEXT_PUBLIC_DOCS_URL=http://localhost:4002

# Optional footer link
# NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/Skndan/partha

# CI / Docker build only
# SKIP_ENV_VALIDATION=1
