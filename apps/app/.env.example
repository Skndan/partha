# Local development for @partha/app (port 4000)
#
#   cp .env.example .env.local
#
# Root `.env.local` is also loaded by Next.js / MCP scripts when present.

NODE_ENV=development

# PostgreSQL — local: createdb -U postgres partha
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/partha

# Better Auth — required; generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4000

# App public origin (no trailing slash)
NEXT_PUBLIC_URL=http://localhost:4000

# Optional footer link
# NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/Skndan/partha

# Google OAuth (required by env schema; use placeholders until configured)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (optional — verification / password reset)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Cloudflare R2 (optional — only if using /api/upload)
# R2_BUCKET_NAME=
# R2_ENDPOINT=

# CI / Docker build only
# SKIP_ENV_VALIDATION=1

# Integration tests (CI)
# RUN_INTEGRATION_TESTS=1

# MCP local tooling (optional)
# MCP_ACCESS_TOKEN=
