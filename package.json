{
  "name": "partha-app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:app": "turbo build --filter=@partha/app",
    "build:site": "turbo build --filter=@partha/site",
    "build:docs": "turbo build --filter=@partha/docs",
    "dev": "turbo dev",
    "dev:app": "turbo dev --filter=@partha/app",
    "dev:site": "turbo dev --filter=@partha/site",
    "dev:docs": "turbo dev --filter=@partha/docs",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test --filter=@partha/app",
    "test:integration": "turbo test:integration --filter=@partha/app",
    "start:app": "turbo start --filter=@partha/app",
    "start:site": "turbo start --filter=@partha/site",
    "start:docs": "turbo start --filter=@partha/docs",
    "db:generate": "turbo db:generate --filter=@partha/app",
    "db:migrate": "turbo db:migrate --filter=@partha/app",
    "db:push": "turbo db:push --filter=@partha/app",
    "db:studio": "turbo db:studio --filter=@partha/app"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
