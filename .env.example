# Partha environment template
#
# Local app development (recommended):
#   cp apps/app/.env.example apps/app/.env.local
#   cp apps/site/.env.example apps/site/.env.local   # optional
#   cp apps/docs/.env.example apps/docs/.env.local   # optional
#
# Docker Compose on a server:
#   cp .env.example .env
#   Edit image pins, secrets, and public URLs, then: docker compose up -d
#
# TLS deploy script (writes `.env` from `.env.local`):
#   cp .env.example .env.local
#   ./scripts/deploy-ssl-and-up.sh your-domain.com
#
# Image tags are semver only (see apps/*/package.json). CI publishes:
#   <version>  |  <version>-<git-sha>  |  sha-<git-sha>

# -----------------------------------------------------------------------------
# Docker Compose — container images (production pins)
# -----------------------------------------------------------------------------
# Uncomment and set after CI publishes to GHCR (owner must be lowercase).

# APP_IMAGE=ghcr.io/your-org/partha-app:0.1.0
# SITE_IMAGE=ghcr.io/your-org/partha-site:0.1.0
# DOCS_IMAGE=ghcr.io/your-org/partha-docs:0.0.0

# -----------------------------------------------------------------------------
# Docker Compose — Postgres (optional overrides)
# -----------------------------------------------------------------------------
POSTGRES_DB=partha
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Deploy script — Let's Encrypt (optional)
# -----------------------------------------------------------------------------
# CERTBOT_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Runtime — shared across Compose services using env_file: .env
# -----------------------------------------------------------------------------
NODE_ENV=production

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/partha

# Core product (@partha/app) — no trailing slash
NEXT_PUBLIC_URL=https://your-domain.com

# Marketing site (@partha/site)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_DOCS_URL=https://docs.your-domain.com

# Optional
# NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/Skndan/partha

# Better Auth — openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://your-domain.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Cloudflare R2 (optional — /api/upload)
# R2_BUCKET_NAME=
# R2_ENDPOINT=

# Docker build / CI only
# SKIP_ENV_VALIDATION=1
