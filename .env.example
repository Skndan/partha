# Copy to `.env` for Docker Compose, or `.env.local` under `apps/app` / `apps/site` for local dev.

NODE_ENV=development

# PostgreSQL — one URL; the app picks the right driver from the host (Neon vs local).
#
# Local: database `partha`, user/password `postgres` / `postgres` (adjust host/port if needed)
#   createdb -U postgres partha
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/partha
#
# Neon (staging/production): paste from the Neon dashboard. Pooler URLs use the same code path as local.
# DATABASE_URL=postgresql://...

# Core product (`apps/app`) — no trailing slash
NEXT_PUBLIC_URL=http://localhost:4000

# Marketing site (`apps/site`) — optional; used for metadataBase / Open Graph
NEXT_PUBLIC_SITE_URL=http://localhost:4001

# Where marketing CTAs link for login/signup (core app origin)
NEXT_PUBLIC_APP_URL=http://localhost:4000

# Documentation site (`apps/docs`) — marketing `/docs` redirects here (no trailing slash)
NEXT_PUBLIC_DOCS_URL=http://localhost:4002

# Optional: marketing footer repository link
# NEXT_PUBLIC_GITHUB_REPO_URL=

# Better Auth — generate a long random string for production
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4000

# Google OAuth — fill from Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: email for verification / password reset
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Cloudflare R2 (S3-compatible). Set all four when using /api/upload.
R2_BUCKET_NAME=your-bucket-name
R2_ENDPOINT=https://example.r2.cloudflarestorage.com

# Skip strict env validation (e.g. CI lint / Docker build)
# SKIP_ENV_VALIDATION=1
